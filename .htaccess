# ==============================================================================
# SPHERE MISSION CONTROL - APACHE WEBSERVER CONFIGURATION
# Optimized for Web Performance, Security Hardening, and High-Speed Asset Caching
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. DIRECTORY SETTINGS & ROUTING defaults
# ------------------------------------------------------------------------------
DirectoryIndex index.html

# Prevent folder indexing/browsing for security
Options -Indexes

# ------------------------------------------------------------------------------
# 2. GZIP COMPRESSION (via mod_deflate)
# Reduces payload weight of HTML, CSS, Javascript, and SVGs by up to 70%
# ------------------------------------------------------------------------------
<IfModule mod_deflate.c>
    # Force compression for common text types
    AddOutputFilterByType DEFLATE text/html
    AddOutputFilterByType DEFLATE text/css
    AddOutputFilterByType DEFLATE text/plain
    AddOutputFilterByType DEFLATE text/xml
    AddOutputFilterByType DEFLATE text/javascript
    AddOutputFilterByType DEFLATE application/javascript
    AddOutputFilterByType DEFLATE application/x-javascript
    AddOutputFilterByType DEFLATE application/json
    AddOutputFilterByType DEFLATE application/xml
    AddOutputFilterByType DEFLATE application/xhtml+xml
    AddOutputFilterByType DEFLATE application/rss+xml
    AddOutputFilterByType DEFLATE application/atom+xml
    AddOutputFilterByType DEFLATE application/x-font-ttf
    AddOutputFilterByType DEFLATE application/x-font-opentype
    AddOutputFilterByType DEFLATE application/vnd.ms-fontobject
    AddOutputFilterByType DEFLATE image/svg+xml
    AddOutputFilterByType DEFLATE image/x-icon
    AddOutputFilterByType DEFLATE image/x-win-bitmap

    # Handle proxy server decompression compatibility
    <IfModule mod_headers.c>
        Header append Vary User-Agent
    </IfModule>
</IfModule>

# ------------------------------------------------------------------------------
# 3. LEVERAGE BROWSER CACHING (via mod_expires)
# Instructs the browser to cache static assets locally to eliminate redundant requests
# ------------------------------------------------------------------------------
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresDefault "access plus 1 month"

    # HTML files - No-cache to guarantee instant deployment updates
    ExpiresByType text/html "access plus 0 seconds"

    # Data feeds / XML / JSON
    ExpiresByType application/json "access plus 0 seconds"
    ExpiresByType application/xml "access plus 0 seconds"
    ExpiresByType text/xml "access plus 0 seconds"

    # CSS & JavaScript - 1 month cache (use cache busting on code modification)
    ExpiresByType text/css "access plus 1 month"
    ExpiresByType text/javascript "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
    ExpiresByType application/x-javascript "access plus 1 month"

    # High-fidelity Vector Diagrams & Images
    ExpiresByType image/svg+xml "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/gif "access plus 1 year"
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/webp "access plus 1 year"
    ExpiresByType image/x-icon "access plus 1 year"

    # Web Fonts (Google Fonts / local assets)
    ExpiresByType font/ttf "access plus 1 year"
    ExpiresByType font/otf "access plus 1 year"
    ExpiresByType font/woff "access plus 1 year"
    ExpiresByType font/woff2 "access plus 1 year"
    ExpiresByType application/font-woff "access plus 1 year"
</IfModule>

# ------------------------------------------------------------------------------
# 4. HTTP SECURITY HARDENING HEADERS (via mod_headers)
# Guards the laboratory portal against common clickjacking and MIME-sniffing exploits
# ------------------------------------------------------------------------------
<IfModule mod_headers.c>
    # Avoid Clickjacking by preventing third-party frame embedding
    Header set X-Frame-Options "SAMEORIGIN"

    # Block MIME-sniffing attacks (forces standard browser content-type parsing)
    Header set X-Content-Type-Options "nosniff"

    # Enable built-in browser XSS protection block filters
    Header set X-XSS-Protection "1; mode=block"

    # Referrer policy to control link leakages
    Header set Referrer-Policy "strict-origin-when-cross-origin"

    # Disable caching for critical HTML templates to guarantee fresh dynamic UI
    <FilesMatch "\.(html|htm)$">
        Header set Cache-Control "no-cache, no-store, must-revalidate"
        Header set Pragma "no-cache"
        Header set Expires 0
    </FilesMatch>
</IfModule>

# ------------------------------------------------------------------------------
# 5. HTTPS REDIRECT (Optional - Enabled when deployed on secure ports)
# ------------------------------------------------------------------------------
<IfModule mod_rewrite.c>
    RewriteEngine On
    
    # Redirection rule for forcing HTTPS (uncomment below if hosting on secure public servers)
    # RewriteCond %{HTTPS} off
    # RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]
</IfModule>
